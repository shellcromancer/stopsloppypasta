# -------------------------------------------------------
# Dot-directories: ignore all, allowlist what we track
# -------------------------------------------------------
.*/
!.claude/
!.github/
!.specs/
!.renovate/

# -------------------------------------------------------
# OS
# -------------------------------------------------------
.DS_Store
Thumbs.db

# -------------------------------------------------------
# Secrets & environment
# -------------------------------------------------------
.env
.envrc
*.*key
*.pem
*.pgp
*.pub
.config.env
.decrypted~*

# -------------------------------------------------------
# AI tooling (local/personal files only)
# -------------------------------------------------------
CLAUDE.md
CLAUDE.local.md
.claude/settings.local.json
docs/superpowers/

# -------------------------------------------------------
# Editors
# -------------------------------------------------------
*.profraw

# -------------------------------------------------------
# Python
# -------------------------------------------------------
__pycache__/
*.py[cod]
*.egg-info/
.coverage
.coverage.*

# -------------------------------------------------------
# Dependencies & build output
# -------------------------------------------------------
node_modules/
build/
dist/
site/
**/cache/

# -------------------------------------------------------
# Temp, logs, & working files
# -------------------------------------------------------
*.bak
*.log
*.old
*old*
*.iso
*.zip
.temp*
.task/
.logs/
TODO.md

# -------------------------------------------------------
# Repo-specific
# -------------------------------------------------------
.worktrees/
_site/

# -------------------------------------------------------
# Retain (must be last -- negations override above)
# -------------------------------------------------------
!.gitkeep
!.gitignore
!.env.example
!.env.sample
